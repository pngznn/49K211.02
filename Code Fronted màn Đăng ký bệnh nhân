<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đăng ký bệnh nhân - CliniCare</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --primary:#3152B8;
      --primary-dark:#2846A3;
      --bg:#f3f4f6;
      --card:#ffffff;
      --text:#1f2937;
      --muted:#6b7280;
      --border:#d8dee9;
      --input-bg:#ffffff;
      --shadow:0 10px 24px rgba(15, 23, 42, 0.08);
      --radius-xl:18px;
      --radius-lg:14px;
      --radius-md:12px;
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    body{
      font-family:"Inter", sans-serif;
      background:var(--bg);
      min-height:100vh;
      color:var(--text);
    }

    .page{
      min-height:100vh;
      display:grid;
      grid-template-columns: 1fr 1.15fr;
    }

    .left-panel{
      background:var(--primary);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:40px;
    }

    .brand-block{
      text-align:center;
      color:#fff;
    }

    .brand-icon{
      width:82px;
      height:82px;
      margin:0 auto 28px;
      border-radius:20px;
      background:rgba(255,255,255,0.14);
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:inset 0 1px 0 rgba(255,255,255,0.12);
    }

    .brand-icon span{
      font-size:38px;
      font-weight:800;
      line-height:1;
    }

    .brand-name{
      font-size:46px;
      font-weight:800;
      margin-bottom:18px;
      letter-spacing:-0.5px;
    }

    .brand-desc{
      font-size:18px;
      font-weight:400;
      color:rgba(255,255,255,0.88);
    }

    .right-panel{
      display:flex;
      align-items:center;
      justify-content:center;
      padding:40px;
      background:#f5f5f7;
    }

    .register-card{
      width:100%;
      max-width:430px;
      background:var(--card);
      border:1px solid #eceff4;
      border-radius:20px;
      box-shadow:var(--shadow);
      padding:34px 34px 30px;
    }

    .title{
      font-size:28px;
      font-weight:800;
      margin-bottom:8px;
      color:#1f2937;
    }

    .subtitle{
      font-size:16px;
      color:var(--muted);
      margin-bottom:28px;
    }

    .field{
      margin-bottom:18px;
    }

    .label{
      display:block;
      font-size:14px;
      font-weight:600;
      color:#374151;
      margin-bottom:10px;
    }

    .input-wrap{
      position:relative;
    }

    .input,
    .select{
      width:100%;
      height:44px;
      border:1px solid var(--border);
      border-radius:12px;
      background:var(--input-bg);
      padding:0 14px;
      font-size:14px;
      color:#111827;
      outline:none;
      transition:0.2s ease;
    }

    .input::placeholder{
      color:#9ca3af;
    }

    .input:focus,
    .select:focus{
      border-color:var(--primary);
      box-shadow:0 0 0 3px rgba(49,82,184,0.10);
    }

    .input.has-right{
      padding-right:42px;
    }

    .icon-right{
      position:absolute;
      right:12px;
      top:50%;
      transform:translateY(-50%);
      width:20px;
      height:20px;
      display:flex;
      align-items:center;
      justify-content:center;
      color:#98a2b3;
      pointer-events:none;
    }

    .btn-submit{
      width:100%;
      height:44px;
      border:none;
      border-radius:12px;
      background:linear-gradient(180deg, #3d60d7 0%, var(--primary) 100%);
      color:#fff;
      font-size:16px;
      font-weight:700;
      cursor:pointer;
      margin-top:6px;
      margin-bottom:24px;
      box-shadow:0 8px 18px rgba(49,82,184,0.22);
      transition:0.2s ease;
    }

    .btn-submit:hover{
      transform:translateY(-1px);
    }

    .bottom-text{
      text-align:center;
      font-size:14px;
      color:var(--muted);
    }

    .bottom-text a{
      color:#4f6ef7;
      text-decoration:none;
      font-weight:600;
    }

    .bottom-text a:hover{
      text-decoration:underline;
    }

    svg{
      display:block;
    }

    @media (max-width: 1100px){
      .page{
        grid-template-columns:1fr;
      }

      .left-panel{
        min-height:280px;
      }

      .brand-name{
        font-size:40px;
      }
    }

    @media (max-width: 640px){
      .left-panel,
      .right-panel{
        padding:20px;
      }

      .register-card{
        padding:24px 20px;
      }

      .title{
        font-size:24px;
      }

      .subtitle{
        font-size:14px;
      }

      .brand-name{
        font-size:34px;
      }

      .brand-desc{
        font-size:15px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="left-panel">
      <div class="brand-block">
        <div class="brand-icon">
          <span>C</span>
        </div>
        <div class="brand-name">CliniCare</div>
        <div class="brand-desc">Chăm sóc sức khỏe dễ dàng hơn mỗi ngày</div>
      </div>
    </div>

    <div class="right-panel">
      <div class="register-card">
        <h1 class="title">Tạo tài khoản</h1>
        <p class="subtitle">Đăng ký để đặt lịch khám nhanh chóng</p>

        <div class="field">
          <label class="label">Họ và tên</label>
          <input class="input" type="text" placeholder="Nguyễn Văn A">
        </div>

        <div class="field">
          <label class="label">Email</label>
          <input class="input" type="email" placeholder="example@email.com">
        </div>

        <div class="field">
          <label class="label">Số điện thoại</label>
          <input class="input" type="text" placeholder="0912 345 678">
        </div>

        <div class="field">
          <label class="label">Giới tính</label>
          <div class="input-wrap">
            <select class="select">
              <option selected disabled>Chọn giới tính</option>
              <option>Nam</option>
              <option>Nữ</option>
              <option>Khác</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label class="label">Mật khẩu</label>
          <div class="input-wrap">
            <input class="input has-right" type="password" placeholder="••••••••">
            <span class="icon-right">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M2 12C3.8 8.8 7.2 6.5 12 6.5C16.8 6.5 20.2 8.8 22 12C20.2 15.2 16.8 17.5 12 17.5C7.2 17.5 3.8 15.2 2 12Z" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
              </svg>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label">Xác nhận mật khẩu</label>
          <div class="input-wrap">
            <input class="input has-right" type="password" placeholder="••••••••">
            <span class="icon-right">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M2 12C3.8 8.8 7.2 6.5 12 6.5C16.8 6.5 20.2 8.8 22 12C20.2 15.2 16.8 17.5 12 17.5C7.2 17.5 3.8 15.2 2 12Z" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
              </svg>
            </span>
          </div>
        </div>

        <button class="btn-submit">Đăng ký</button>

        <div class="bottom-text">
          Đã có tài khoản? <a href="#">Đăng nhập</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
