                                <td>09:30</td>
                                <td><span class="status-badge status-confirmed">Đã xác nhận</span></td>
                            </tr>
                            <tr>
                                <td>7</td>
                                <td>LH007</td>
                                <td class="patient-name">Bùi Văn Sơn</td>
                                <td>BS. Hoàng Thị Lan</td>
                                <td>Chỉnh hình</td>
                                <td>04/04/2026</td>
                                <td>11:30</td>
                                <td><span class="status-badge status-confirmed">Đã xác nhận</span></td>
                            </tr>
                            <tr>
                                <td>8</td>
                                <td>LH008</td>
                                <td class="patient-name">Ngô Thị Thanh</td>
                                <td>BS. Phạm Minh Tuấn</td>
                                <td>Thần kinh</td>
                                <td>05/04/2026</td>
                                <td>13:00</td>
                                <td><span class="status-badge status-cancelled">Đã hủy</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pagination">
                    <p class="pagination-info">
                        Hiển thị <span>1-8</span> trong <span>24</span> lịch hẹn
                    </p>
                    <div class="pagination-buttons">
                        <button class="pagination-btn">Trước</button>
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn">2</button>
                        <button class="pagination-btn">3</button>
                        <button class="pagination-btn">Sau</button>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
