<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CliniCare - Trang chủ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #E5E7EB;
        }

        .container {
            width: 1492px;
            height: 925px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            border-radius: 8px;
            position: relative;
        }

        /* Sidebar */
        .sidebar {
            width: 210px;
            height: 925px;
            background: #2F56C0;
            display: flex;
            flex-direction: column;
            padding: 24px 0;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
            padding: 0 20px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            flex-shrink: 0;
        }

        .logo-icon::before,
        .logo-icon::after {
            content: '';
            position: absolute;
            background: #2F56C0;
        }

        .logo-icon::before {
            width: 18px;
            height: 3.5px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 10px;
        }

        .logo-icon::after {
            width: 3.5px;
            height: 18px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 10px;
        }

        .logo-text {
            color: white;
            font-weight: 600;
            font-size: 15px;
            line-height: 1;
        }

        .menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 0 16px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 12px;
            border-radius: 8px;
            color: rgba(255, 255, 255, 0.7);
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
            font-weight: 500;
            text-align: left;
            font-family: 'Inter', sans-serif;
            opacity: 0.7;
        }

        .menu-item:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .menu-item.active {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            opacity: 1;
        }

        .menu-item svg {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
        }

        .menu-divider {
            flex: 1;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #F5F6F8;
        }

        /* Top Navigation */
        .top-nav {
            height: 64px;
            background: white;
            border-bottom: 1px solid #E5E7EB;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
        }

        .top-nav-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .top-nav-logo-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            flex-shrink: 0;
        }

        .top-nav-logo-icon::before,
        .top-nav-logo-icon::after {
            content: '';
            position: absolute;
            background: #111827;
        }

        .top-nav-logo-icon::before {
            width: 14px;
            height: 2.8px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 10px;
        }

        .top-nav-logo-icon::after {
            width: 2.8px;
            height: 14px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 10px;
        }

        .top-nav-logo-text {
            color: #111827;
            font-weight: 600;
            font-size: 15px;
            line-height: 1;
        }

        .top-nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .search-bar {
            position: relative;
        }

        .search-bar input {
            width: 280px;
            padding: 9px 16px 9px 38px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            font-weight: 400;
            border-radius: 8px;
            border: 1px solid #D1D5DB;
            color: #111827;
            outline: none;
            transition: all 0.2s;
        }

        .search-bar input::placeholder {
            color: #99A1AF;
            font-family: 'Inter', sans-serif;
            font-weight: 400;
        }

        .search-bar input:focus {
            border-color: #2F56C0;
            box-shadow: 0 0 0 3px rgba(47, 86, 192, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            color: #9CA3AF;
        }

        .notification-btn {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            background: transparent;
            cursor: pointer;
            transition: background 0.2s;
        }

        .notification-btn:hover {
            background: #F3F4F6;
        }

        .user-section {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #2F56C0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
            font-weight: 500;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: #111827;
        }

        /* Content Area */
        .content {
            flex: 1;
            overflow: hidden;
            padding: 24px;
        }

        .content-inner {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        /* Hero Section */
        .hero {
            background: #2F56C0;
            border-radius: 12px;
            padding: 32px;
            text-align: center;
            margin-bottom: 24px;
        }

        .hero h1 {
            font-size: 30px;
            font-weight: 700;
            color: white;
            margin-bottom: 8px;
        }

        .hero p {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 24px;
        }

        .hero button {
            padding: 12px 32px;
            background: white;
            color: #2F56C0;
            border: none;
            border-radius: 8px;
            font-weight: 500;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .hero button:hover {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        /* Doctors Section */
        .section {
            margin-bottom: 24px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: #111827;
            margin-bottom: 16px;
        }

        .doctors-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .doctor-card {
            background: white;
            border-radius: 12px;
            padding: 16px;
            border: 1px solid #F3F4F6;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .doctor-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #2F56C0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 500;
            font-size: 18px;
            margin: 0 auto 12px;
        }

        .doctor-info {
            text-align: center;
            margin-bottom: 12px;
        }

        .doctor-name {
            font-weight: 500;
            color: #111827;
            margin-bottom: 4px;
        }

        .doctor-specialty {
            font-size: 14px;
            color: #6B7280;
            margin-bottom: 8px;
        }

        .doctor-status {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
        }

        .doctor-status.available {
            background: #F0FDF4;
            color: #15803D;
        }

        .doctor-status.busy {
            background: #F3F4F6;
            color: #6B7280;
        }

        .doctor-btn {
            width: 100%;
            padding: 8px;
            background: #2F56C0;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .doctor-btn:hover {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        /* Departments Grid */
        .departments-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }

        .department-card {
            background: white;
            border-radius: 12px;
            padding: 16px;
            border: 1px solid #F3F4F6;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .department-card:hover {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .department-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .department-icon svg {
            width: 20px;
            height: 20px;
        }

        .department-name {
            font-size: 14px;
            font-weight: 500;
            color: #111827;
            text-align: center;
        }

        /* Chatbot Button */
        .chatbot-button {
            position: absolute;
            bottom: 24px;
            right: 24px;
            width: 56px;
            height: 56px;
            background: #2F56C0;
            border: none;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 8px 16px rgba(47, 86, 192, 0.3);
            transition: all 0.2s;
            z-index: 1000;
        }

        .chatbot-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(47, 86, 192, 0.4);
        }

        .chatbot-button svg {
            width: 28px;
            height: 28px;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar">
            <!-- Logo -->
            <div class="logo">
                <div class="logo-icon"></div>
                <div class="logo-text">CliniCare</div>
            </div>

            <!-- Menu -->
            <nav class="menu">
                <button class="menu-item active">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    <span>Trang chủ</span>
