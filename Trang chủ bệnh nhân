                                <button class="doctor-btn">Đặt lịch</button>
                            </div>
                            <div class="doctor-card">
                                <div class="doctor-avatar">L</div>
                                <div class="doctor-info">
                                    <div class="doctor-name">BS. Phạm Lan</div>
                                    <div class="doctor-specialty">Thần kinh</div>
                                    <span class="doctor-status available">Đang làm</span>
                                </div>
                                <button class="doctor-btn">Đặt lịch</button>
                            </div>
                        </div>
                    </div>

                    <!-- Departments -->
                    <div class="section">
                        <h2 class="section-title">Chuyên khoa</h2>
                        <div class="departments-grid">
                            <div class="department-card">
                                <div class="department-icon" style="background: rgba(239, 68, 68, 0.08);">
