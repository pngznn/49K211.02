<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CliniCare - Chi tiết lịch hẹn</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f9fafb;
            color: #111827;
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 210px;
            height: 100vh;
            background-color: #2F56C0;
            color: white;
            display: flex;
            flex-direction: column;
            z-index: 40;
        }

        .sidebar-header {
            padding: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo-icon {
            background-color: white;
            color: #2F56C0;
            border-radius: 8px;
            padding: 8px;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            font-size: 16px;
            font-weight: 600;
        }

        .sidebar-nav {
            flex: 1;
            padding: 12px;
            overflow-y: auto;
        }

        .menu-item {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 4px;
            background: transparent;
            border: none;
            color: white;
            text-align: left;
            font-size: 14px;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .menu-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .menu-item.active {
            background-color: rgba(255, 255, 255, 0.2);
        }

        .sidebar-footer {
            padding: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
        }

        /* Main Content */
        .main-wrapper {
            margin-left: 210px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .header {
            background-color: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-title {
            font-size: 20px;
            font-weight: 600;
            color: #1f2937;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .search-box {
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
        }

        .search-input {
            padding: 8px 16px 8px 40px;
            background-color: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            width: 256px;
            font-size: 14px;
            outline: none;
        }

        .search-input:focus {
            border-color: #2F56C0;
            box-shadow: 0 0 0 2px rgba(47, 86, 192, 0.2);
        }

        .user-name {
            font-size: 14px;
            font-weight: 500;
            color: #374151;
        }

        /* Content Area */
        .content {
            flex: 1;
            padding: 24px;
        }

        /* Page Header */
        .page-header {
            background-color: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 16px 24px;
            margin: -24px -24px 24px -24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-title {
            font-size: 20px;
            font-weight: 600;
            color: #111827;
        }

        .page-actions {
            display: flex;
            gap: 12px;
        }

        .btn {
            padding: 8px 16px;
            font-size: 14px;
            font-weight: 500;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-secondary {
            background-color: transparent;
            color: #6b7280;
            border: 1px solid transparent;
        }

        .btn-secondary:hover {
            background-color: #f3f4f6;
        }

        .btn-primary {
            background-color: #2F56C0;
            color: white;
        }

        .btn-primary:hover {
            background-color: #2847a0;
        }

        .btn-danger {
            background-color: #ef4444;
            color: white;
        }

        .btn-danger:hover {
            background-color: #dc2626;
        }

        /* Grid Layout */
        .detail-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Card */
        .card {
            background-color: white;
            border-radius: 12px;
            border: 1px solid #f3f4f6;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
            padding: 24px;
            margin-bottom: 24px;
        }

        .card:last-child {
            margin-bottom: 0;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            color: #111827;
        }

        /* Status Badge */
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            font-size: 12px;
            font-weight: 500;
            border-radius: 9999px;
        }

        .status-confirmed {
            background-color: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .info-item {
            display: flex;
            flex-direction: column;
        }

        .info-label {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .info-value {
            font-size: 14px;
            font-weight: 500;
            color: #111827;
        }

        .info-full {
            grid-column: 1 / -1;
        }

        .reason-box {
            background-color: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 12px;
            margin-top: 8px;
        }

        .reason-text {
            font-size: 14px;
            color: #374151;
            line-height: 1.6;
        }

        /* Summary List */
        .summary-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .summary-label {
            font-size: 14px;
            color: #6b7280;
        }

        .summary-value {
            font-size: 14px;
            font-weight: 500;
            color: #111827;
            text-align: right;
        }

        /* Alert Box */
        .alert {
            border-radius: 12px;
            padding: 16px;
            border: 1px solid;
        }

        .alert-warning {
            background-color: #fef3c7;
            border-color: #fbbf24;
        }

        .alert-danger {
            background-color: #fee2e2;
            border-color: #fca5a5;
        }

        .alert-title {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .alert-warning .alert-title {
            color: #92400e;
        }

        .alert-danger .alert-title {
            color: #991b1b;
        }

        .alert-text {
            font-size: 14px;
            line-height: 1.6;
        }

        .alert-warning .alert-text {
            color: #78350f;
        }

        .alert-danger .alert-text {
            color: #7f1d1d;
        }

        /* History Timeline */
        .history-timeline {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .history-item {
            display: flex;
            gap: 12px;
        }

        .history-content {
            flex: 1;
            padding-bottom: 16px;
        }

        .history-action {
            font-size: 14px;
            color: #111827;
            margin-bottom: 4px;
        }

        .history-date {
            font-size: 12px;
            color: #6b7280;
        }

        /* Icons */
        .icon {
            width: 16px;
            height: 16px;
        }

        .icon-lg {
            width: 20px;
            height: 20px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .main-wrapper {
                margin-left: 0;
            }

            .sidebar {
                display: none;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo-icon">
                <svg class="icon-lg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
            </div>
            <h1 class="logo-text">CliniCare</h1>
        </div>

        <nav class="sidebar-nav">
            <button class="menu-item">Trang chủ</button>
            <button class="menu-item active">Quản lý lịch hẹn</button>
            <button class="menu-item">Quản lý khoa và bác sĩ</button>
            <button class="menu-item">Quản lý chat bot</button>
            <button class="menu-item">Cài đặt</button>
        </nav>

        <div class="sidebar-footer">
            <button class="menu-item">Đăng xuất</button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Header -->
        <header class="header">
            <h2 class="header-title">Quản lý lịch hẹn</h2>
            <div class="header-right">
                <div class="search-box">
                    <svg class="search-icon icon-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input type="text" class="search-input" placeholder="Tìm bác sĩ, chuyên khoa...">
                </div>
                <span class="user-name">Quản trị viên</span>
            </div>
        </header>

        <!-- Content Area -->
        <main class="content">
            <!-- Page Header -->
            <div class="page-header">
                <h1 class="page-title">Chi tiết lịch hẹn</h1>
                <div class="page-actions">
                    <button class="btn btn-secondary">
                        <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Quay lại
                    </button>
                    <button class="btn btn-primary">Chỉnh sửa</button>
                    <button class="btn btn-danger">Hủy lịch</button>
                </div>
            </div>

            <!-- Detail Grid -->
            <div class="detail-grid">
                <!-- Left Column -->
                <div>
                    <!-- Thông tin lịch hẹn -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="card-title">Thông tin lịch hẹn</h2>
                            <span class="status-badge status-confirmed">Đã xác nhận</span>
                        </div>

                        <div class="info-grid">
                            <div class="info-item">
                                <p class="info-label">Mã lịch hẹn</p>
                                <p class="info-value">LH001</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Ngày tạo lịch</p>
                                <p class="info-value">16/03/2026 - 08:00</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Ngày khám</p>
                                <p class="info-value">02/04/2026</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Khung giờ</p>
                                <p class="info-value">09:00 - 09:30</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Khoa khám</p>
                                <p class="info-value">Tim mạch</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Bác sĩ phụ trách</p>
                                <p class="info-value">BS. Trần Thị Mai</p>
                            </div>
                        </div>

                        <div class="info-full" style="margin-top: 24px;">
                            <p class="info-label" style="margin-bottom: 8px;">Lý do khám</p>
                            <div class="reason-box">
                                <p class="reason-text">Bệnh nhân cần khám định kỳ tim mạch, kiểm tra huyết áp và các chỉ số sức khỏe.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin bệnh nhân -->
                    <div class="card">
                        <h2 class="card-title" style="margin-bottom: 24px;">Thông tin bệnh nhân</h2>

                        <div class="info-grid">
                            <div class="info-item">
                                <p class="info-label">Họ và tên</p>
                                <p class="info-value">Nguyễn Văn An</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Số điện thoại</p>
                                <p class="info-value">0901 234 567</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Giới tính</p>
                                <p class="info-value">Nam</p>
                            </div>
                            <div class="info-item">
                                <p class="info-label">Ngày sinh</p>
                                <p class="info-value">15/08/1985</p>
                            </div>
                        </div>
                    </div>

                    <!-- Lịch sử xử lý -->
                    <div class="card">
                        <h2 class="card-title" style="margin-bottom: 24px;">Lịch sử xử lý</h2>

                        <div class="history-timeline">
                            <div class="history-item">
                                <div class="history-content">
                                    <p class="history-action">Đã cập nhật lịch hẹn</p>
                                    <p class="history-date">16/03/2026 - 08:00</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div>
                    <!-- Tóm tắt nhanh -->
                    <div class="card">
                        <h2 class="card-title" style="margin-bottom: 24px;">Tóm tắt nhanh</h2>

                        <div class="summary-list">
                            <div class="summary-item">
                                <p class="summary-label">Mã lịch hẹn</p>
                                <p class="summary-value">LH001</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Bệnh nhân</p>
                                <p class="summary-value">Nguyễn Văn An</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Khoa khám</p>
                                <p class="summary-value">Tim mạch</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Bác sĩ</p>
                                <p class="summary-value">BS. Trần Thị Mai</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Ngày khám</p>
                                <p class="summary-value">02/04/2026</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Giờ khám</p>
                                <p class="summary-value">09:00</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Trạng thái</p>
                                <span class="status-badge status-confirmed">Đã xác nhận</span>
                            </div>
                        </div>
                    </div>

                    <!-- Lưu ý quản trị -->
                    <div class="alert alert-danger">
                        <h3 class="alert-title">Lưu ý quản trị</h3>
                        <p class="alert-text">Lịch hẹn này đã được xác nhận. Nếu cần hủy hoặc đổi giờ khám, vui lòng liên hệ bệnh nhân trước để đảm bảo minh bạch thông tin.</p>
                    </div>

                    <!-- Thông tin liên hệ bác sĩ -->
                    <div class="card">
                        <h2 class="card-title" style="margin-bottom: 24px;">Thông tin liên hệ bác sĩ</h2>

                        <div class="summary-list">
                            <div class="summary-item">
                                <p class="summary-label">Bác sĩ</p>
                                <p class="summary-value">BS. Trần Thị Mai</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Chuyên môn</p>
                                <p class="summary-value">Tim mạch</p>
                            </div>
                            <div class="summary-item">
                                <p class="summary-label">Phòng khám</p>
                                <p class="summary-value">Phòng 101 - Tầng 1</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
