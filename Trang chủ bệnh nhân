                                </div>
                                <div class="department-name">Nhi khoa</div>
                            </div>
                            <div class="department-card">
                                <div class="department-icon" style="background: rgba(139, 92, 246, 0.08);">
                                    <svg fill="none" stroke="#8B5CF6" viewBox="0 0 24 24"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
